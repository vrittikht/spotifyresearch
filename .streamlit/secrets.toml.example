# Copy this file to secrets.toml and fill in your credentials.
# secrets.toml is gitignored — never commit real keys.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_SERVICE_KEY = "your-supabase-service-role-key"

GROQ_API_KEY = "your-groq-api-key"
GROQ_MODEL = "llama-3.1-8b-instant"

# Optional: User-Agent for public Reddit page requests (no API key needed)
REDDIT_USER_AGENT = "spotify-research-collector/1.0 (PM case study; public pages only)"
